generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// PLATAFORMA (Painel Master)
// ============================================

model Plan {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  maxOrdersMonth  Int
  maxOperators    Int
  hasReports      Boolean  @default(false)
  hasAdvReports   Boolean  @default(false)
  hasNfce         Boolean  @default(false)
  hasPrinting     Boolean  @default(false)
  hasRepeatOrder  Boolean  @default(false)
  hasPhotoImport  Boolean  @default(false)
  hasWhatsappCmd  Boolean  @default(false)
  hasCustomDomain Boolean  @default(false)
  hasCashRegister Boolean  @default(false)
  hasLoyalty      Boolean  @default(false)
  hasKds          Boolean  @default(false)
  hasTableOrder   Boolean  @default(false)
  hasSalesRecovery Boolean @default(false)
  hasMarketingPixels Boolean @default(false)
  hasAiSuggestions Boolean @default(false)
  hasBulkWhatsapp Boolean @default(false)
  hasDeliveryApp  Boolean  @default(false)
  hasMarketplace  Boolean  @default(false)
  hasMultiUnit    Boolean  @default(false)
  hasBranding     Boolean  @default(true)
  price           Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tenants         Tenant[]
}

model PlatformConfig {
  id                    String   @id @default(cuid())
  defaultAiModel        String   @default("gpt-4.1-mini")
  defaultAiProvider     String   @default("openai")
  platformOpenaiKey     String?
  alertTelegramBotToken String?
  alertTelegramChatId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model MasterAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("Admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// TENANT (Loja)
// ============================================

model Tenant {
  id             String   @id @default(cuid())
  slug           String   @unique
  name           String
  phone          String
  email          String
  address        String?
  logoUrl        String?
  primaryColor   String   @default("#1A5276")
  secondaryColor String   @default("#2E86C1")
  customDomain   String?  @unique
  isActive       Boolean  @default(true)
  trialEndsAt    DateTime?

  orderMode         OrderMode       @default(CLIENT_CHOOSES)
  minOrderValue     Decimal?        @db.Decimal(10, 2)
  deliveryFeeMode   DeliveryFeeMode @default(FIXED)
  fixedDeliveryFee  Decimal?        @db.Decimal(10, 2)
  maxDeliveryRadius Decimal?        @db.Decimal(5, 2)
  estimatedDelivery String          @default("40-60 min")

  feedbackDelayMin Int     @default(120)
  feedbackEnabled  Boolean @default(true)

  reengageEnabled Boolean @default(false)
  reengageDays    Int     @default(30)
  reengageMessage String?

  aiMode          AiMode @default(PLATFORM_KEY)
  aiModel         String @default("gpt-4.1-mini")
  tenantOpenaiKey String?
  aiMonthlyTokens Int    @default(0)
  aiTokenLimit    Int?

  pixAutoEnabled    Boolean @default(false)
  pixOnDelivery     Boolean @default(true)
  cardCreditEnabled Boolean @default(true)
  cardDebitEnabled  Boolean @default(true)
  cashEnabled       Boolean @default(true)
  creditFeePercent  Decimal @default(0) @db.Decimal(5, 2)
  debitFeePercent   Decimal @default(0) @db.Decimal(5, 2)

  pspProvider    String?
  pspCredentials Json?

  nfceEnabled     Boolean @default(false)
  nfceProvider    String?
  nfceCredentials Json?
  nfceFiscalData  Json?
  nfceAutoEmit    Boolean @default(false)

  msgReceived    String @default("Pedido recebido! Estamos preparando.")
  msgPreparing   String @default("Seu pedido está sendo preparado!")
  msgOutDelivery String @default("Seu pedido saiu para entrega!")
  msgDelivered   String @default("Pedido entregue! Obrigado pela preferência!")

  whatsappStatus      WhatsappStatus @default(DISCONNECTED)
  whatsappQrCode      String?
  whatsappSessionData Json?

  printerType    String?  // 'network' | 'usb'
  printerIp      String?
  printerPort    Int?     @default(9100)
  printerWidth   Int?     @default(48) // 32 = 58mm, 48 = 80mm
  autoPrintOrder Boolean  @default(false)
  autoPrintKitchen Boolean @default(false)

  loyaltyEnabled      Boolean @default(false)
  loyaltyPointsPerReal Int     @default(1)   // pontos por R$1 gasto
  loyaltyMinOrderValue Decimal? @db.Decimal(10, 2) // pedido mínimo para ganhar pontos

  dineInEnabled Boolean @default(false)

  recoveryEnabled     Boolean @default(false)
  recoveryDelayMin    Int     @default(30)
  recoveryMessage     String  @default("Oi! Notamos que seu pedido foi cancelado. Que tal tentar novamente? Estamos prontos para atendê-lo! 🍕")
  recoveryDiscountPct Int     @default(0)

  facebookPixelId   String?
  googleAnalyticsId String?
  googleAdsId       String?
  tiktokPixelId     String?

  planId         String
  plan           Plan            @relation(fields: [planId], references: [id])
  categories     Category[]
  menuItems      MenuItem[]
  orders         Order[]
  customers      Customer[]
  operators      Operator[]
  operatingHours OperatingHour[]
  deliveryZones  DeliveryZone[]
  campaigns      Campaign[]
  adminPhones    AdminPhone[]
  dailyMenus     DailyMenu[]
  cashRegisters       CashRegister[]
  loyaltyRewards      LoyaltyReward[]
  loyaltyTransactions LoyaltyTransaction[]
  dineInTables        DineInTable[]
  recoveryAttempts    RecoveryAttempt[]
  marketplaceIntegrations MarketplaceIntegration[]
  groupMemberships        TenantGroupMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([customDomain])
}

// ============================================
// GRUPO DE FILIAIS (Multi-Unit)
// ============================================

model TenantGroup {
  id          String              @id @default(cuid())
  name        String
  ownerTenantId String            // The tenant that created/owns the group
  members     TenantGroupMember[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([ownerTenantId])
}

model TenantGroupMember {
  id        String          @id @default(cuid())
  groupId   String
  group     TenantGroup     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      GroupMemberRole @default(BRANCH)
  createdAt DateTime        @default(now())

  @@unique([groupId, tenantId])
  @@index([tenantId])
}

enum GroupMemberRole {
  HEADQUARTERS  // Matriz
  BRANCH        // Filial
}

enum OrderMode {
  ALWAYS_SITE
  ALWAYS_WHATSAPP
  CLIENT_CHOOSES
}

enum DeliveryFeeMode {
  FIXED
  DISTANCE_BASED
}

enum AiMode {
  PLATFORM_KEY
  TENANT_KEY
  HYBRID
}

enum WhatsappStatus {
  CONNECTED
  DISCONNECTED
  CONNECTING
  BANNED
}

// ============================================
// OPERAÇÃO
// ============================================

model OperatingHour {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dayOfWeek Int
  openTime  String
  closeTime String
  isOpen    Boolean @default(true)

  @@unique([tenantId, dayOfWeek])
}

model AdminPhone {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone     String
  name      String
  role      AdminRole @default(OPERATOR)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())

  @@unique([tenantId, phone])
}

enum AdminRole {
  OWNER
  OPERATOR
  DRIVER
}

model Operator {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name             String
  email            String
  password         String
  role             AdminRole @default(OPERATOR)
  isActive         Boolean   @default(true)
  emailConfirmedAt DateTime?
  confirmToken     String?
  driverLat        Decimal?  @db.Decimal(10, 8)
  driverLng        Decimal?  @db.Decimal(11, 8)
  driverLocationAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  driverOrders     Order[]   @relation("DriverOrders")

  @@unique([tenantId, email])
}

// ============================================
// CARDÁPIO
// ============================================

model Category {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  sortOrder     Int      @default(0)
  availableFrom String?
  availableTo   String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  items         MenuItem[]

  @@index([tenantId, sortOrder])
}

model MenuItem {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal   @db.Decimal(10, 2)
  imageUrl    String?
  sortOrder   Int       @default(0)
  isPaused    Boolean   @default(false)
  isTemporary Boolean   @default(false)
  expiresAt   DateTime?

  ncm  String?
  cfop String?
  csosn String?

  // Inventory control
  trackStock        Boolean @default(false)
  stockQuantity     Int     @default(0)
  lowStockThreshold Int     @default(5)

  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]

  @@index([tenantId, categoryId, sortOrder])
  @@index([isTemporary, expiresAt])
}

model DailyMenu {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date        DateTime  @db.Date
  rawInput    String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([tenantId, date])
}

// ============================================
// ESTOQUE (Inventory)
// ============================================

model InventoryMovement {
  id         String            @id @default(cuid())
  tenantId   String
  menuItemId String
  menuItem   MenuItem          @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  type       InventoryMoveType
  quantity   Int
  reason     String?
  orderId    String?
  createdAt  DateTime          @default(now())

  @@index([tenantId, menuItemId])
  @@index([tenantId, createdAt])
}

enum InventoryMoveType {
  IN          // Entrada de estoque (reposição)
  OUT         // Saída manual
  SALE        // Saída por venda (pedido)
  ADJUSTMENT  // Ajuste de inventário
  RETURN      // Devolução
}

// ============================================
// ENTREGA
// ============================================

model DeliveryZone {
  id          String  @id @default(cuid())
  tenantId    String
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  minDistance  Decimal? @db.Decimal(5, 2)
  maxDistance  Decimal? @db.Decimal(5, 2)
  fee         Decimal  @db.Decimal(10, 2)
  isActive    Boolean  @default(true)

  @@index([tenantId])
}

// ============================================
// CLIENTES
// ============================================

model Customer {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone         String
  name          String?
  address       String?
  addressRef    String?
  latitude      Decimal?  @db.Decimal(10, 8)
  longitude     Decimal?  @db.Decimal(11, 8)
  isRegistered  Boolean   @default(false)
  lastOrderAt   DateTime?
  lastContactAt DateTime?
  feedbackAvg   Decimal?  @db.Decimal(3, 2)
  feedbackCount Int       @default(0)
  totalOrders   Int       @default(0)
  totalSpent    Decimal   @default(0) @db.Decimal(10, 2)
  loyaltyPoints Int       @default(0)

  orders              Order[]
  loyaltyTransactions LoyaltyTransaction[]
  recoveryAttempts    RecoveryAttempt[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([tenantId, phone])
  @@index([tenantId, lastOrderAt])
  @@index([tenantId, lastContactAt])
}

// ============================================
// PEDIDOS
// ============================================

model Order {
  id         String @id @default(cuid())
  tenantId   String
  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])
  driverId   String?
  driver     Operator? @relation("DriverOrders", fields: [driverId], references: [id])
  orderNumber Int

  status    OrderStatus @default(RECEIVED)
  orderType OrderType   @default(DELIVERY)
  tableNumber String?

  deliveryAddress String?
  deliveryRef     String?
  deliveryLat     Decimal? @db.Decimal(10, 8)
  deliveryLng     Decimal? @db.Decimal(11, 8)

  subtotal    Decimal @db.Decimal(10, 2)
  deliveryFee Decimal @default(0) @db.Decimal(10, 2)
  cardFee     Decimal @default(0) @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)

  paymentMethod    PaymentMethod
  paymentStatus    PaymentStatus @default(PENDING)
  needsChange      Boolean       @default(false)
  changeFor        Decimal?      @db.Decimal(10, 2)
  pspTransactionId String?
  pspPixCode       String?
  pspPixQrCode     String?

  marketplaceSource  MarketplaceSource?
  marketplaceOrderId String?

  generalNotes String?

  nfceXml       String?
  nfceDanfeUrl  String?
  nfceNumber    String?
  nfceEmittedAt DateTime?

  feedbackRating  Int?
  feedbackComment String?
  feedbackAt      DateTime?
  feedbackSentAt  DateTime?

  estimatedDelivery String?
  confirmedAt       DateTime?
  preparingAt       DateTime?
  outDeliveryAt     DateTime?
  deliveredAt       DateTime?
  cancelledAt       DateTime?
  cancelReason      String?

  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  recoveryAttempts RecoveryAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, orderNumber])
  @@index([customerId])
  @@index([driverId])
  @@index([marketplaceSource, marketplaceOrderId])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  name       String
  price      Decimal  @db.Decimal(10, 2)
  quantity   Int
  notes      String?
  kdsStatus  KdsItemStatus @default(PENDING)

  @@index([orderId])
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())

  @@index([orderId])
}

enum OrderStatus {
  RECEIVED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum KdsItemStatus {
  PENDING     // Aguardando preparo
  PREPARING   // Em preparo
  READY       // Pronto
}

enum OrderType {
  DELIVERY    // Entrega
  PICKUP      // Retirada
  TABLE       // Mesa (garçom digital)
}

enum PaymentMethod {
  PIX_AUTO
  PIX_DELIVERY
  CREDIT_CARD
  DEBIT_CARD
  CASH
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  REFUNDED
}

enum MarketplaceSource {
  IFOOD
  RAPPI
}

// ============================================
// MARKETPLACES (iFood / Rappi)
// ============================================

model MarketplaceIntegration {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        MarketplaceSource
  credentials     String?           // encrypted JSON (tokens, merchantId, etc)
  merchantId      String?           // marketplace merchant/store ID
  status          MarketplaceStatus @default(DISCONNECTED)
  catalogSyncedAt DateTime?
  lastWebhookAt   DateTime?
  webhookSecret   String?           // HMAC secret for webhook validation
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([tenantId, provider])
  @@index([provider, merchantId])
}

enum MarketplaceStatus {
  CONNECTED
  DISCONNECTED
  PENDING       // awaiting marketplace approval
  ERROR
}

// ============================================
// GARÇOM DIGITAL (Mesas / QR Code)
// ============================================

model DineInTable {
  id        String  @id @default(cuid())
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number    String  // "1", "2", "A1", etc.
  name      String? // "Varanda 1", "Salão 3"
  capacity  Int     @default(4)
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, number])
  @@index([tenantId, isActive])
}

// ============================================
// CAMPANHAS E REENGAJAMENTO
// ============================================

model Campaign {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  message        String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  audienceFilter Json?
  targetCount    Int            @default(0)
  sentCount      Int            @default(0)
  failedCount    Int            @default(0)
  scheduledAt    DateTime?
  sentAt         DateTime?
  createdAt      DateTime       @default(now())
  messages       CampaignMessage[]

  @@index([tenantId])
  @@index([status, scheduledAt])
}

model CampaignMessage {
  id         String                @id @default(cuid())
  campaignId String
  campaign   Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  phone      String
  status     CampaignMessageStatus @default(PENDING)
  sentAt     DateTime?
  error      String?

  @@index([campaignId])
}

enum CampaignType {
  PROMOTIONAL
  REENGAGEMENT
  RECOVERY
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum CampaignMessageStatus {
  PENDING
  SENT
  FAILED
}

// ============================================
// RECUPERAÇÃO DE VENDAS (Sales Recovery)
// ============================================

model RecoveryAttempt {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  message    String
  sentAt     DateTime @default(now())
  recovered  Boolean  @default(false)
  recoveredOrderId String?
  recoveredAt DateTime?

  @@index([tenantId, sentAt])
  @@index([orderId])
  @@index([customerId])
}

// ============================================
// GESTÃO DE CAIXA (Cash Register)
// ============================================

model CashRegister {
  id              String             @id @default(cuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  openedBy        String             // operator name
  closedBy        String?
  openingBalance  Decimal            @db.Decimal(10, 2)
  closingBalance  Decimal?           @db.Decimal(10, 2)
  expectedBalance Decimal?           @db.Decimal(10, 2)
  status          CashRegisterStatus @default(OPEN)
  notes           String?
  openedAt        DateTime           @default(now())
  closedAt        DateTime?
  movements       CashMovement[]

  @@index([tenantId, status])
  @@index([tenantId, openedAt])
}

model CashMovement {
  id             String           @id @default(cuid())
  tenantId       String
  cashRegisterId String
  cashRegister   CashRegister     @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  type           CashMovementType
  amount         Decimal          @db.Decimal(10, 2)
  description    String?
  orderId        String?
  operatorName   String
  createdAt      DateTime         @default(now())

  @@index([cashRegisterId])
  @@index([tenantId, createdAt])
}

enum CashRegisterStatus {
  OPEN
  CLOSED
}

enum CashMovementType {
  SALE        // Venda (entrada automática)
  DEPOSIT     // Suprimento / depósito
  WITHDRAWAL  // Sangria / retirada
  EXPENSE     // Despesa
}

// ============================================
// PROGRAMA DE FIDELIDADE (Loyalty)
// ============================================

model LoyaltyReward {
  id             String  @id @default(cuid())
  tenantId       String
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String  // ex: "Hambúrguer Grátis"
  description    String?
  pointsCost     Int     // pontos necessários para resgatar
  type           LoyaltyRewardType @default(FREE_ITEM)
  discountValue  Decimal? @db.Decimal(10, 2) // valor do desconto se type=DISCOUNT
  menuItemId     String?  // item grátis se type=FREE_ITEM
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, isActive])
}

model LoyaltyTransaction {
  id         String              @id @default(cuid())
  tenantId   String
  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       LoyaltyTransactionType
  points     Int                 // positivo=ganho, negativo=resgate
  balance    Int                 // saldo após transação
  orderId    String?             // pedido que gerou os pontos
  rewardId   String?             // reward resgatado
  description String?
  createdAt  DateTime            @default(now())

  @@index([tenantId, customerId])
  @@index([tenantId, createdAt])
}

enum LoyaltyRewardType {
  FREE_ITEM   // Item grátis do cardápio
  DISCOUNT    // Desconto em valor fixo
  PERCENTAGE  // Desconto percentual
}

enum LoyaltyTransactionType {
  EARN        // Ganho por pedido
  REDEEM      // Resgate de recompensa
  ADJUSTMENT  // Ajuste manual
  EXPIRE      // Expiração de pontos
}

// ============================================
// CONVERSAS E SESSÕES DO CHATBOT
// ============================================

model ChatSession {
  id            String   @id @default(cuid())
  tenantId      String
  customerPhone String
  state         Json
  lastMessage   DateTime @default(now())
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, customerPhone])
  @@index([expiresAt])
}

// ============================================
// LOGS E MÉTRICAS
// ============================================

model AiUsageLog {
  id               String   @id @default(cuid())
  tenantId         String
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  costEstimate     Decimal? @db.Decimal(10, 6)
  createdAt        DateTime @default(now())

  @@index([tenantId, createdAt])
}

model WhatsappLog {
  id          String   @id @default(cuid())
  tenantId    String
  direction   String
  phone       String
  messageType String
  content     String?
  createdAt   DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, phone])
}
